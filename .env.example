# Local development — copy to .env (never commit .env)
EXPO_PUBLIC_GROQ_API_KEY=your_groq_key_here

# PostHog (US Cloud) — project API key from PostHog → Settings → Project token
EXPO_PUBLIC_POSTHOG_KEY=phc_YOUR_KEY_HERE
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional: override where the app checks for APK updates
# EXPO_PUBLIC_UPDATE_MANIFEST_URL=https://yourdomain.com/flowly/version.json
