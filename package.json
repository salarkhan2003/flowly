{
  "name": "flowly",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eas": "eas-cli",
    "eas:configure": "eas-cli build:configure",
    "eas:build:android": "eas-cli build --platform android --profile production",
    "eas:env:groq": "eas-cli env:create --name EXPO_PUBLIC_GROQ_API_KEY --scope project --environment production --environment preview --visibility secret --type string",
    "eas:env:posthog": "eas-cli env:create --name EXPO_PUBLIC_POSTHOG_KEY --scope project --environment production --environment preview --visibility secret --type string"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/analytics": "^24.0.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/crashlytics": "^24.0.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.17",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.7",
    "expo-sharing": "~14.0.8",
    "expo-speech-recognition": "^3.1.3",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "posthog-react-native": "^4.45.16",
    "posthog-react-native-session-replay": "^1.6.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.5",
    "react-native-webview": "^13.15.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
